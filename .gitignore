.pio/

# PlatformIO regenerates these and they hardcode absolute local paths.
# extensions.json is machine-independent, so it stays tracked.
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/.browse.c_cpp.db*
.vscode/ipch/

# Local artifacts of the user's checkpointing skill — session scratch, regenerated
# on demand. Canonical repo state lives in STATUS.md and in git history.
CHECKPOINT.md
CHECKPOINT.diff

__pycache__/
*.pyc
